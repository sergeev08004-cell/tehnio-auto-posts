{
  "telegram": {
    "bot_token": "dry-run-token",
    "channel_id": "@dry_run_channel",
    "parse_mode": "HTML",
    "disable_web_page_preview": false
  },
  "poll_interval_minutes": 30,
  "max_posts_per_cycle": 3,
  "min_post_age_minutes": 5,
  "max_post_age_hours": 720,
  "min_publish_gap_minutes": 0,
  "request_timeout_seconds": 5,
  "database_path": "data/sample-news.db",
  "user_agent": "AutoNewsBot/1.0 (local dry run)",
  "publication_title": "",
  "translation": {
    "enabled": false,
    "provider": "google_web",
    "target_language": "ru",
    "source_languages": [
      "en"
    ]
  },
  "editorial": {
    "profile": "tehnio",
    "insider_label": "🕵️‍♂️ ИНСАЙД",
    "news_label": "✅ НОВОСТЬ",
    "link_text": "Подробности ниже 👇",
    "persona_comments_enabled": true,
    "subscribe_cta_text": "⚔️ Вступить в легион TehNio!"
  },
  "llm": {
    "enabled": false,
    "provider": "openai",
    "model": "gpt-4o-mini",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.6,
    "summary_max_sentences": 4,
    "persona_max_chars": 180
  },
  "diversity": {
    "enabled": true,
    "max_per_publisher": 1,
    "max_per_topic": 2,
    "topic_repeat_penalty": 1.15,
    "publisher_repeat_penalty": 0.85,
    "topic_limits": {
      "recalls": 1
    }
  },
  "sources": [
    {
      "name": "SampleFeed",
